+func TestCropKittyImage(t *testing.T) {
+	img := image.NewRGBA(image.Rect(0, 0, 4, 4))
+	for y := 0; y < 4; y++ {
+		for x := 0; x < 4; x++ {
+			img.Set(x, y, color.RGBA{R: uint8(x), G: uint8(y), B: 0, A: 255})
+		}
+	}
+
+	cropped := cropKittyImage(img, kittyParams{srcX: 1, srcY: 2, srcW: 2, srcH: 1})
+	if cropped.Bounds().Dx() != 2 || cropped.Bounds().Dy() != 1 {
+		t.Fatalf("cropped size = %dx%d, want 2x1", cropped.Bounds().Dx(), cropped.Bounds().Dy())
+	}
+	r, g, _, _ := cropped.At(0, 0).RGBA()
+	if r>>8 != 1 || g>>8 != 2 {
+		t.Fatalf("cropped first pixel = (%d,%d), want (1,2)", r>>8, g>>8)
+	}
+
+	clipped := cropKittyImage(img, kittyParams{srcX: 3, srcY: 3, srcW: 10, srcH: 10})
+	if clipped.Bounds().Dx() != 10 || clipped.Bounds().Dy() != 10 {
+		t.Fatalf("clipped size = %dx%d, want 10x10", clipped.Bounds().Dx(), clipped.Bounds().Dy())
+	}
+	r, g, _, _ = clipped.At(0, 0).RGBA()
+	if r>>8 != 3 || g>>8 != 3 {
+		t.Fatalf("clipped first pixel = (%d,%d), want (3,3)", r>>8, g>>8)
+	}
+	_, _, _, a := clipped.At(1, 1).RGBA()
+	if a != 0 {
+		t.Fatalf("clipped padded pixel alpha = %d, want 0", a)
+	}
+
+	if got := cropKittyImage(img, kittyParams{srcX: 10, srcY: 10, srcW: 1, srcH: 1}); got.Bounds().Dx() != 1 || got.Bounds().Dy() != 1 {
+		t.Fatalf("out-of-bounds crop size = %dx%d, want 1x1", got.Bounds().Dx(), got.Bounds().Dy())
+	}
+}
