+			wantDelete: 'a',
+			wantData:   "",
+		},
+		{
+			name:       "delete by id",
+			payload:    "Ga=d,d=i,i=10",
+			wantAction: 'd',
+			wantDelete: 'i',
+			wantID:     10,
+			wantData:   "",
+		},
+		{
+			name:       "place by id",
+			payload:    "Ga=p,i=10",
+			wantAction: 'p',
+			wantID:     10,
+			wantData:   "",
+		},
+		{
+			name:       "no params just data",
+			payload:    "G;base64stuff",
+			wantAction: 'T',
+			wantFormat: 32,
+			wantData:   "base64stuff",
