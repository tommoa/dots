+func TestKittyTransmitAndPlace(t *testing.T) {
+	// Create a small PNG
+	img := image.NewRGBA(image.Rect(0, 0, 2, 2))
+	for y := 0; y < 2; y++ {
+		for x := 0; x < 2; x++ {
