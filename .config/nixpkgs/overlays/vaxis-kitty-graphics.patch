+			wantAction: 'd',
+			wantDelete: 'a',
+			wantData:   "",
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			params, data, err := parseKittyGraphics(tt.payload)
+			if err != nil {
+				t.Fatalf("unexpected error: %v", err)
