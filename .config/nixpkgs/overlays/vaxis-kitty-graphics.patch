+func (vt *Model) scrollGraphics(delta int) {
+	top := int(vt.margin.top)
+	bottom := int(vt.margin.bottom)
+	for _, img := range vt.graphics {
+		if !img.intersectsRows(top, bottom) {
+			continue
+		}
+		img.origin.row += delta
+	}
+}
+
+func (img *Image) intersectsRows(top, bottom int) bool {
+	rows := img.rows
+	if rows <= 0 {
+		rows = 1
+	}
+	start := img.origin.row
+	end := start + rows - 1
+	return start <= bottom && end >= top
 }
 
